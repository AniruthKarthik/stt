#!/bin/bash
# STT Trigger Daemon
# Listens to all physical input devices for KEY_F8

# Find the directory where this script is located
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WHISPERSTT_PATH="$BIN_DIR/whisperstt"

# Kill any existing instances to avoid duplicates
pkill -f "evtest" 2>/dev/null
pkill -f "whisperstt" 2>/dev/null

echo "Starting STT Trigger Daemon (Listening for F8 Key)..."

# Find and listen to physical input devices only
# We exclude "ydotoold" and other virtual devices to avoid loops
for dev in /dev/input/event*; do
    if [ -c "$dev" ] && [ -r "$dev" ]; then
        NAME=$(cat /sys/class/input/$(basename "$dev")/device/name 2>/dev/null)
        if [[ "$NAME" == *"ydotoold"* || "$NAME" == *"Virtual"* ]]; then
            continue
        fi
        
        (
            stdbuf -oL evtest "$dev" 2>/dev/null | awk -v d="$dev" -v n="$NAME" -v wp="$WHISPERSTT_PATH" '
            /KEY_F8\), value 1/ { 
                print "[Trigger ON: " n " (" d ")]"
                system(wp " start") 
            }
            /KEY_F8\), value 0/ { 
                print "[Trigger OFF: " n " (" d ")]"
                system(wp " stop") 
            }
            '
        ) &
    fi
done

wait
