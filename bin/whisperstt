#!/bin/bash

# Find the project root directory (one level up from bin)
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$BIN_DIR/.." && pwd)"
TMP_DIR="$PROJECT_DIR/tmp"
PID_FILE="$TMP_DIR/record.pid"
AUDIO_FILE="$TMP_DIR/audio.wav"
LOG_FILE="$TMP_DIR/stt.log"
YDOTOOL_SOCKET="/tmp/.ydotool_socket"
WHISPER_CLI="$PROJECT_DIR/whisper.cpp/build/bin/whisper-cli"
MODEL_PATH="$PROJECT_DIR/models/ggml-base.en.bin"

mkdir -p "$TMP_DIR"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }

# Helper to type text via ydotool
type_text() {
    YDOTOOL_SOCKET="$YDOTOOL_SOCKET" ydotool type "$1" 2>>"$LOG_FILE"
}

# Helper to type text safely
type_text_safely() {
    # If we are in start mode, we might still be holding the Copilot key.
    # The Copilot key is often Meta+Shift+F23.
    # We add a delay to allow the OS to process the key release.
    sleep 0.2
    YDOTOOL_SOCKET="$YDOTOOL_SOCKET" ydotool type "$1" 2>>"$LOG_FILE"
}

# Helper to press a key via ydotool (14 is BackSpace)
press_key() {
    YDOTOOL_SOCKET="$YDOTOOL_SOCKET" ydotool key "$1":1 "$1":0 2>>"$LOG_FILE"
}

case "$1" in
    start)
        if [ -f "$PID_FILE" ]; then
            log "Already recording. Skipping."
            exit 0
        fi
        log "--- START RECORDING ---"
        
        # Inline feedback
        type_text_safely "recording..."
        
        rm -f "$AUDIO_FILE"
        
        # Start recording
        arecord -f S16_LE -r 16000 -c 1 -q "$AUDIO_FILE" 2>>"$LOG_FILE" &
        REC_PID=$!
        echo $REC_PID > "$PID_FILE"
        ;;
        
    stop)
        # Give 'start' a tiny moment to write the PID file
        for i in {1..10}; do
            [ -f "$PID_FILE" ] && break
            sleep 0.05
        done

        if [ ! -f "$PID_FILE" ]; then
            log "No recording in progress."
            exit 0
        fi
        
        PID=$(cat "$PID_FILE")
        rm -f "$PID_FILE"
        
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID" 2>/dev/null
            wait "$PID" 2>/dev/null
        fi
        
        log "Recording stopped. Transcribing..."
        
        # Erase "recording..." (12 characters)
        # We wait for the release of the key before backspacing
        sleep 0.1
        for i in {1..12}; do
            press_key 14
        done
        
        TEXT=$("$WHISPER_CLI" \
            -m "$MODEL_PATH" \
            -f "$AUDIO_FILE" \
            -nt 2>>"$LOG_FILE" \
            | tail -n 1 \
            | sed 's/^ *//;s/ *$//')
        
        # Basic Hallucination/Silence Filter
        if [[ -z "$TEXT" || "$TEXT" =~ ^\[.*\]$ || "$TEXT" =~ ^\(.*\)$ || "$TEXT" == *"BLANK_AUDIO"* ]]; then
            log "Ignored hallucination: '$TEXT'"
            exit 0
        fi
        
        log "Transcription: $TEXT"
        
        type_text_safely "$TEXT "
        log "Injected using ydotool."
        ;;
esac
