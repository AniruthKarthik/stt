#!/usr/bin/zsh

# --- Configuration ---
PROJECT_DIR="/home/ani/stt"
MODEL_PATH="$PROJECT_DIR/models/ggml-base.en.bin"
WHISPER_CLI="$PROJECT_DIR/whisper.cpp/build/bin/whisper-cli"
TMP_DIR="$PROJECT_DIR/tmp"
LOG_FILE="$TMP_DIR/stt.log"
PID_FILE="$TMP_DIR/stt.pid"
AUDIO_FILE="$TMP_DIR/stt_recording.wav"

mkdir -p "$TMP_DIR"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

notify() {
    if command -v notify-send &> /dev/null; then
        notify-send -t 1000 "STT" "$1" &
    fi
}

start_recording() {
    log "--- Toggle Start ---"
    notify "Recording started..."
    rm -f "$AUDIO_FILE"
    
    # Start arecord in background
    arecord -f cd -q "$AUDIO_FILE" &
    local REC_PID=$!
    echo "$REC_PID" > "$PID_FILE"
    log "Recording process started: $REC_PID"
}

stop_recording() {
    log "--- Toggle Stop ---"
    if [[ ! -f "$PID_FILE" ]]; then
        log "Stop requested but no active recording found."
        return
    fi
    
    local PID=$(cat "$PID_FILE")
    rm -f "$PID_FILE"
    
    if kill -0 "$PID" 2>/dev/null; then
        # Small delay to ensure the last bit of audio is captured
        sleep 0.3
        kill "$PID"
        wait "$PID" 2>/dev/null
        log "Recording process stopped."
    else
        log "Warning: Recording process $PID not found."
    fi
    
    if [[ ! -f "$AUDIO_FILE" || ! -s "$AUDIO_FILE" ]]; then
        log "Error: Audio file is missing or empty."
        notify "Error: No audio captured"
        return
    fi

    log "Transcribing..."
    notify "Transcribing..."
    
    local TEXT=$(
    "$WHISPER_CLI" \
        -m "$MODEL_PATH" \
        -f "$AUDIO_FILE" \
        -nt \
        2>>"$LOG_FILE" \
        | tail -n 1 \
        | sed 's/^ *//;s/ *$//'
    )
    
    log "Transcription Result: '$TEXT'"

    # Hallucination filter
    if [[ -z "$TEXT" || "$TEXT" == "[BLANK_AUDIO]" || "$TEXT" == "[MUSIC]" || "$TEXT" == "[MUSIC PLAYING]" || "$TEXT" == "[BLANK]" || "$TEXT" == "[wind]" || "$TEXT" == "[silence]" ]]; then
        log "Discarding result (empty or hallucination: '$TEXT')."
        notify "No speech detected"
        return
    fi

    log "Injecting text into focused window..."
    notify "Typed: $TEXT"
    
    export YDOTOOL_SOCKET="/run/user/$(id -u)/.ydotool_socket"
    if ydotool type "$TEXT " 2>>"$LOG_FILE"; then
        log "Injection successful."
    else
        log "Injection failed."
        notify "Error: Injection failed"
    fi
}

# --- Main Logic ---
if [[ -f "$PID_FILE" ]]; then
    RUNNING_PID=$(cat "$PID_FILE")
    if kill -0 "$RUNNING_PID" 2>/dev/null; then
        # Check file age to avoid rapid double-triggers
        NOW=$(date +%s)
        FILE_TIME=$(stat -c %Y "$PID_FILE")
        if (( NOW - FILE_TIME < 1 )); then
            log "Debounce: Ignoring stop request (too soon after start)."
            exit 0
        fi
        stop_recording
    else
        log "Stale PID file found. Cleaning up and starting new recording."
        rm -f "$PID_FILE"
        start_recording
    fi
else
    start_recording
fi
