#!/zsh

# --- Configuration ---
PROJECT_DIR="/home/ani/stt"
MODEL_PATH="$PROJECT_DIR/models/ggml-base.en.bin"
WHISPER_CLI="$PROJECT_DIR/whisper.cpp/build/bin/whisper-cli"
TMP_DIR="$PROJECT_DIR/tmp"
LOG_FILE="$TMP_DIR/stt.log"
KEY_CODE=201 # Copilot key

# Ensure directories exist
mkdir -p "$TMP_DIR"

# --- Functions ---
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

notify() {
    if command -v notify-send &> /dev/null; then
        notify-send -t 1500 "STT" "$1"
    fi
}

cleanup() {
    log "Cleaning up..."
    # Kill arecord if it's still running
    if [[ -n "$ARECORD_PID" ]]; then
        kill "$ARECORD_PID" 2>/dev/null
    fi
    [[ -f "$AUDIO_FILE" ]] && rm -f "$AUDIO_FILE"
}
trap cleanup EXIT INT TERM

# --- Main ---
AUDIO_FILE="$TMP_DIR/voice_$$.wav"

# 1. Dependency Check
if ! command -v arecord &> /dev/null; then
    log "Error: arecord not found"
    notify "Error: arecord not found"
    exit 1
fi

if [[ ! -f "$WHISPER_CLI" ]]; then
    log "Error: whisper-cli not found at $WHISPER_CLI"
    notify "Error: whisper-cli not found"
    exit 1
fi

# 2. Recording (Start)
log "Starting recording (hold key)..."
notify "Listening..."

# Start recording in background
arecord -f cd -q "$AUDIO_FILE" &
ARECORD_PID=$!

# 3. Wait for key release
# We poll xinput for the key state. 
# Key 201 is XF86TouchpadOff
log "Waiting for key $KEY_CODE release..."

# Find the keyboard ID dynamically if possible, but 9 was seen in previous turn.
# Let's try to be a bit more robust.
KBD_ID=$(xinput list | grep -i "keyboard" | grep -v "XTEST" | head -n 1 | grep -o "id=[0-9]*" | cut -d= -f2)
[[ -z "$KBD_ID" ]] && KBD_ID=9

while true; do
    STATE=$(xinput query-state "$KBD_ID" 2>/dev/null | grep "key\[$KEY_CODE\]")
    if [[ "$STATE" == *"up"* ]]; then
        log "Key $KEY_CODE released."
        break
    fi
    sleep 0.1
done

# Stop recording
kill "$ARECORD_PID" 2>/dev/null
wait "$ARECORD_PID" 2>/dev/null
log "Recording stopped."

if [[ ! -f "$AUDIO_FILE" || ! -s "$AUDIO_FILE" ]]; then
    log "Error: Audio file not created or empty"
    notify "Error: Recording failed"
    exit 1
fi

# 4. Transcription
log "Transcribing..."
notify "Transcribing..."

TEXT=$(
"$WHISPER_CLI" \
    -m "$MODEL_PATH" \
    -f "$AUDIO_FILE" \
    -nt \
    2>>"$LOG_FILE" \
    | tail -n 1 \
    | sed 's/^ *//;s/ *$//'
)

if [[ -z "$TEXT" || "$TEXT" == "[BLANK_AUDIO]" || "$TEXT" == "[MUSIC]" || "$TEXT" == "[MUSIC PLAYING]" ]]; then
    log "No valid text transcribed: $TEXT"
    notify "No speech detected"
    exit 0
fi

# 5. Injection
log "Injecting: $TEXT"
export YDOTOOL_SOCKET="/run/user/$(id -u)/.ydotool_socket"

if ! ydotool type "$TEXT " 2>>"$LOG_FILE"; then
    log "Error: ydotool failed. Socket: $YDOTOOL_SOCKET"
    notify "Error: Injection failed"
    exit 1
fi

notify "Transcribed: $TEXT"
exit 0
