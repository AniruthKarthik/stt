#!/usr/bin/zsh

# --- Configuration ---
PROJECT_DIR="/home/ani/stt"
MODEL_PATH="$PROJECT_DIR/models/ggml-base.en.bin"
WHISPER_CLI="$PROJECT_DIR/whisper.cpp/build/bin/whisper-cli"
TMP_DIR="$PROJECT_DIR/tmp"
LOG_FILE="$TMP_DIR/stt.log"
PID_FILE="$TMP_DIR/stt.pid"
AUDIO_FILE="$TMP_DIR/stt_recording.wav"

mkdir -p "$TMP_DIR"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

notify() {
    if command -v notify-send &> /dev/null; then
        notify-send -t 1000 "STT" "$1" &
    fi
}

start_recording() {
    if [[ -f "$PID_FILE" ]]; then
        local OLD_PID=$(cat "$PID_FILE")
        if kill -0 "$OLD_PID" 2>/dev/null; then
            exit 0
        fi
    fi
    log "--- Triggered ---"
    notify "Listening..."
    rm -f "$AUDIO_FILE"
    arecord -f cd -q "$AUDIO_FILE" &
    echo $! > "$PID_FILE"
}

stop_recording() {
    if [[ ! -f "$PID_FILE" ]]; then return; fi
    local PID=$(cat "$PID_FILE")
    rm -f "$PID_FILE"
    if kill -0 "$PID" 2>/dev/null; then
        sleep 0.2
        kill "$PID"
        wait "$PID" 2>/dev/null
    fi
    log "Recording stopped."
    if [[ ! -f "$AUDIO_FILE" || ! -s "$AUDIO_FILE" ]]; then
        log "Error: No audio captured."
        return
    fi
    log "Transcribing..."
    local TEXT=$(
    "$WHISPER_CLI" \
        -m "$MODEL_PATH" \
        -f "$AUDIO_FILE" \
        -nt \
        2>>"$LOG_FILE" \
        | tail -n 1 \
        | sed 's/^ *//;s/ *$//'
    )
    log "Result: '$TEXT'"
    if [[ -z "$TEXT" || "$TEXT" == "[BLANK_AUDIO]" || "$TEXT" == "[MUSIC]" || "$TEXT" == "[MUSIC PLAYING]" ]]; then
        log "Hallucination ignored."
        return
    fi
    log "Injecting..."
    export YDOTOOL_SOCKET="/run/user/$(id -u)/.ydotool_socket"
    ydotool type "$TEXT " 2>>"$LOG_FILE"
    log "Done."
}

# --- Main ---
start_recording

# Wait for release (max 15 seconds)
log "Waiting for release..."
timeout 15 libinput debug-events | grep --line-buffered "released" | read -r RELEASE_EVENT
log "Release event: $RELEASE_EVENT"

stop_recording
